	var sNoFilhoValor = "value";   			//--> Nó filho com os valores!
  var items         = sObjeto.responseXML.getElementsByTagName(sNoPai);
	var sValor        = 0;
	var iTotalResult  = items.length;
	var aDados        = new Array(iTotalResult, 2);

  //--> Loop Obtendo os valores do nós!
  for(var i = 0; i < items.length; i++)
	{
				//--> Obtendo os Dados!
				sDescricao   = fRetornaDadosElementoNos("", sNoFilhoName, items[i], 0);
