function fRetornaDadosElementoNos(prefix, local, parentElem, index) {
    var result = "";
		//-->
    if (prefix && isIE)
		{   //--> Modo de manipulaçăo do namespaces IE/Windows
        result = parentElem.getElementsByTagName(prefix + ":" + local)[index];
    }
		else
		{   //--> As versőes do namespace deste método (getElementsByTagNameNS())
			  // operam-se diferentemente no safari e no Mozilla, mas ambas retornam
			  // o valor com nome local justo, desde que năo há uns conflitos com
			  // nomes do elemento non-namespace
        result = parentElem.getElementsByTagName(local)[index];
    }
		//-->
    if (result)
		{   //--> Obtendo os Texto dos Nós
        if (result.childNodes.length > 1)
				{
            return result.childNodes[1].nodeValue;
        }
				else
				{
            return result.firstChild.nodeValue;
        }
    }
		else
		{
         return "N/A";
    }
}

