/*############################################################################
### Retorna um select(objeto html) derivado de uma consulta atraves do XML!
############################################################################*/
function fRetornaSelectXML(sUrlXML, sParametros, sNameObjeto, sEventos, sReturn)
{
	//<--- Chamando a Classe XMLDOM
	var parser      = new ActiveXObject("microsoft.xmldom");
	parser.async    = "false"
	parser.load(sUrlXML+"?"+sParametros);                //Lendo o resultado da página
	nodesXML        = parser.documentElement.childNodes; //obtendo os nó filhos
	iTotalElementos = nodesXML.length;                   // Total de Elementos
	//--->

	//<----  Iniciando as vars!
	var oCampo     = "" ;
	var sResult    = "";
	var iAtributos = "";
	var vNode      = "";
	//

	//Montando o Cabeçalho do Select
	sResult = "<select class=oSelect name="+sNameObjeto+" size='1' style='font-size:10px;'"+sEventos+">";
	sResult += "<option class=oSelectSelecione value=''>»» Selecione  &nbsp;&nbsp;</option>";   //Conf. padrăo TelecomWeb!
	//-->

	//<---Obtendo os dados
	for(i=0;i<iTotalElementos;i++){
		 vNode        = nodesXML.item(i);                                    							 //Setando o nó corrente a var!
		 oCampo       = vNode.text;                                          							 //Obtendo os valores do nó passando para var
		 iAtributos   = vNode.getAttribute('value');                                       //Obtendo os Atributos do XML
		 sSelecionado = vNode.getAttribute('selecionado');                                 //Seta selected a opçăo já definida!
		 sResult +="<option value='"+iAtributos+"'"+sSelecionado+">"+oCampo+"</option>";   //Montando o Option
	}
	//---> Fechando o objeto HTML
	sResult +="</select>";

	//---> Opçăo para Retornar o valor ou já renderizar direto no sNameObjeto informado!
    if(!sReturn)
    {
		//--->Atribuindo ao objeto do HTML!
		var oObjeto       = document.getElementById(sNameObjeto);             //Pode ser atribuido ao uma DIV ou TD passando seu iD!
		oObjeto.innerHTML = sResult;
	}
	else
	{
		return sResult;
	}
	//<--- fim
}//FIM fRetornaSelectXML


