###  HTTPREQUEST
#################################################
*/
function fRederizaPagina(URL, sParametros , sObjetoHtml)
{
      var Params = sParametros;
      var XmlRequestUni;

      // create our new Querystring URL
      var PageURL = URL + "?"+Params;
      // Initialize the XmlHttpp object
      try
      {     // Mozilla Browsers
            XmlRequestUni = new XMLHttpRequest();
      }
      catch (e)
      {
            try
            {     // IE based browsers
                  XmlRequestUni = new ActiveXObject("Microsoft.XMLHTTP");
            }
            catch (e)
            {
                  // for all those still using an old browser
                  return false;
            }
      }
      XmlRequestUni.open("GET", PageURL, true);
      XmlRequestUni.onreadystatechange = function(){

            //##################################################################
            //********** Verifica o State do XmlRequest ************************
            //var TesteState = VerificaCallbackState(XmlRequestUni,Method);
            var vTesteState = false;

            if (XmlRequestUni == null)
            {
                vTesteState = false;
            }
            else
            {
                  obj = null;
                  obj = document.getElementById(sObjetoHtml); //Setando a Div!
                  if (obj == null)
                  {
                        alert('AVISO: Objeto năo localizado!  Informe o nome de uma TD, TR ou DIV!');
                        return false;
                  }
                  switch (XmlRequestUni.readyState)
                  {
                        case 1, 2, 3:
                             obj.innerHTML = "<br><br><center><font face='arial' size=2><b> Carregando! </b><br><img src='../../imagens/Loading.gif' border='0'><br><br><br><br>";
                             obj.style.visibility = 'visible';
                             break;
                        case 4:
                             obj.innerHTML = XmlRequestUni.responseText;
			     obj.style.visibility = 'visible';
                             break;
                        default:
                             obj.innerHTML = "<br><br><center><font face='arial' size=2><b> Carregando! </b><br><img src='../../imagens/Loading.gif' border='0'><br><br><br><br>"
                             obj.style.visibility = 'visible';
                             break;
                  }
                  //return true;
                  vTesteState = true;
            }
            //***********Fim do Verifica o State do XmlRequest******************
            //##################################################################
      }
      XmlRequestUni.setRequestHeader("Content-Type", "application/x-www-form-urlencoded");
      XmlRequestUni.send(null);
      return XmlRequestUni;
}

