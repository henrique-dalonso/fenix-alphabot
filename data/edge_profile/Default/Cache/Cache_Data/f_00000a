/*###################################################
### Retorna valores para um <input type(objeto html)
### derivado de uma consulta atraves do XML!
###################################################*/
function fRetornaInputXML(sUrlXML, sParametros, sNameObjeto, iSize, sReturn, sEventos, iStatus)
{
	//<--- Chamando a Classe XMLDOM
	var parser      = new ActiveXObject("microsoft.xmldom");
	parser.async    = "false";
	parser.load(sUrlXML+"?"+sParametros);                				//Lendo o resultado da página
	nodesXML        = parser.documentElement.childNodes; 				//obtendo os nó filhos
	iTotalElementos = nodesXML.length;                   				// Total de Elementos
	//--->

	//<----  Iniciando as vars!
	var oCampo     = "";
	var sResult    = "";
	var iAtributos = "";
	var vNode      = "";
	//-->

	//Verificando o status do objeto(disabled = 1 ou 0)
	var sDisabled = "";
	if(iStatus)sDisabled = 'disabled = 1';


	//Montando o Cabeçalho do Select
	sResult += "<input type='text' nome='"+sNameObjeto+"' size='"+iSize+"' value='";
	//-->

	//<---Obtendo os dados
	for(i=0;i<iTotalElementos;i++){
		 vNode       = nodesXML.item(i);                  				//Setando o nó corrente a var!
		 oCampo      = vNode.text;                        				//Obtendo os valores do nó passando para var
		 iAtributos  = vNode.getAttribute('value');       				//Obtendo os Atributos do XML
		 if(oCampo == ""){
		 	  sResult  = "Cód. Inválido!";
		 }else{
		    sResult  += oCampo;                   //Montando Resultado final
		 }

	}
	//---> Fechando o objeto HTML
	sResult +="' class='oText'  "+sDisabled+" "+sEventos+">";

	//---> Opçăo para Retornar o valor ou já renderizar direto no sNameObjeto informado!
    if(!sReturn)
    {
		//--->Atribuindo ao objeto do HTML!
		var oObjeto       = document.getElementById(sNameObjeto);   //Rederizando o valor no objeto <div><td><del> do HTML
		oObjeto.innerHTML = sResult;
	}
	else
	{
		return sResult;
	}
	//<--- fim
}//FIM fRetornaInputXML


function sleep(milliseconds) {
  var start = new Date().getTime();
  for (var i = 0; i < 1e7; i++) {
    if ((new Date().getTime() - start) > milliseconds){
      break;
    }
  }
}

