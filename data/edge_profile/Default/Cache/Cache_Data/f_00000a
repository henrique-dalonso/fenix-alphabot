//-->funçăo que retorna a biblioteca mais recente para o I.E
function fCriarObjMSXMLHttp()
{	
 	//--> array com as versőes da biblioteca MSXML
  	var versoes = ["MSXML2.XMLHttp.6.0","MSXML2.XMLHttp.5.0",
			"MSXML2.XMLHttp.4.0","MSXML2.XMLHttp.3.0",
			"MSXML2.XMLHttp","Microsoft.XMLHttp"];
  			//--> laço para verificar a versăo que o brownser aceita
  			for(var i = 0; i < versoes.length; i++)
  			{

  				try{
  					var objetoXMLHttp = new ActiveXObject(versoes[i]);
  					return objetoXMLHttp;
  				}catch (ex){
  					//--> Nada Aqui
  				}
			}
			throw new Error("MSXML năo está instalado.");
}



