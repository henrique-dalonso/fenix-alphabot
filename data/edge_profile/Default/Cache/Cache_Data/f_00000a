			 oAjax = fCriarObjMSXMLHttp();
			 //oAjax = window.ActiveXObject(Microsoft.XMLHttp);
		}
		//-->se criou o objeto ajax
		if(oAjax)
		{
			 oAjax.open("GET",sUrl, true);
			 oAjax.send(null);
			 //-->
			 if(oAjax.readyState == 1)
			 {
					var iTotalOpt = oObjetoRetorno.options.length;
					for(i=0; i < iTotalOpt; i++)
	 				{   //oObjetoRetorno.removeChild(oObjetoRetorno.options);
						  oObjetoRetorno.removeChild(oObjetoRetorno.lastChild);
					}
					if(oObjetoRetorno.options.length > 0)oObjetoRetorno.removeChild(oObjetoRetorno.lastChild);

					var sTextRetorno   = document.createTextNode("Aguarde Carregando... ");
					var sOptListaDupla = document.createElement("option");

					sOptListaDupla.appendChild(sTextRetorno);
					oObjetoRetorno.appendChild(sOptListaDupla);

	 		 }

			 oAjax.onreadystatechange = function () {
	 				//--> Status de Leitura...
					if(oAjax.readyState == 2 || oAjax.readyState == 3)
					{
							var iTotalOpt = oObjetoRetorno.options.length;
							for(i=0; i < iTotalOpt; i++)
	 						{
									oObjetoRetorno.removeChild(oObjetoRetorno.lastChild);
							}
					}

					if(oAjax.readyState == 4)
					{
							if(oAjax.status == 200)
							{
									var iTotalOpt = oObjetoRetorno.options.length;
									for(i=0; i < iTotalOpt; i++)
	 								{ 	//oObjetoRetorno.remove(0);
										  oObjetoRetorno.removeChild(oObjetoRetorno.lastChild);
									}

									var oResultado     = oAjax.responseXML;
									var iTotalRegistro = oResultado.getElementsByTagName('result').length;
									var oRegistro      = oResultado.getElementsByTagName('result');

									for(var i = 0; i < iTotalRegistro ; i++)
									{
											var oItem      = oRegistro[i];
											var sOpcao     = oItem.getElementsByTagName('name')[0].firstChild.nodeValue;
											var sValor     = oItem.getElementsByTagName('value')[0].firstChild.nodeValue;
											var sSelecao   = oItem.getElementsByTagName('selected')[0].firstChild.nodeValue;
											var sTextOpcao = document.createTextNode(sOpcao);
											var oNewOption = document.createElement("option");
											//nova_opcao.setAttribute("value",sValor);
											oNewOption.value = sValor;
											oNewOption.appendChild(sTextOpcao);
											oObjetoRetorno.appendChild(oNewOption);

											if(sSelecao == "SIM")
											{
												oNewOption.selected  = true;
											}
									}
							}
					}
			 }
    }
}

