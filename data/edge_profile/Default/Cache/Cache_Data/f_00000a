/*##############################################################
### Retorna array derivado da regras Cob atraves do XML!
##############################################################*/
function fRetornaCobValoresXML(sUrlXML, sParametros)
{
	//<---- Chamando a Classe XMLDOM
	var parser      = new ActiveXObject("microsoft.xmldom")
	parser.async    = "false"
	parser.load(sUrlXML+"?"+sParametros);                				//Lendo o resultado da página

	//<---- Setando os Nós Filhos
	nodesCorrecao   = parser.getElementsByTagName("correcao");
	nodesJuros      = parser.getElementsByTagName("juros");
	nodesMulta      = parser.getElementsByTagName("multa");
	nodesSubTotal   = parser.getElementsByTagName("subtotal");
	nodesComissao   = parser.getElementsByTagName("comissao");
	nodesTotal      = parser.getElementsByTagName("total");

	//<---- Total de Elementos
	iTotalElementos = nodesSubTotal.length;

	//<---- Iniciando as vars!
	var oValor      = "";
	var sResultado  = "";
	var iAtributos  = "";
	var vNode       = "";
	//-->

	aResultado      = new Array();

	//<---Obtendo os dados
	for(i=0;i<iTotalElementos;i++)
	{
		// Correçăo
		vNodeCorrecao = nodesCorrecao.item(i); //Setando o nó filho a var!
		oVlrCorrecao  = vNodeCorrecao.text;    //Obtendo os valores do nó passando para var

		// Juros
		vNodeJuros    = nodesJuros.item(i);    //Setando o nó filho a var!
		oVlrJuros     = vNodeJuros.text;       //Obtendo os valores do nó passando para var

		// Multa
		vNodeMulta    = nodesMulta.item(i);    //Setando o nó filho a var!
		oVlrMulta     = vNodeMulta.text;       //Obtendo os valores do nó passando para var

		// SubTotal
		vNodeSubTotal = nodesSubTotal.item(i); //Setando o nó filho a var!
		oVlrSubTotal  = vNodeSubTotal.text;    //Obtendo os valores do nó passando para var

		// Comissăo
		vNodeComissao = nodesComissao.item(i); //Setando o nó filho a var!
		oVlrComissao  = vNodeComissao.text;    //Obtendo os valores do nó passando para var

		// Total
		vNodeTotal    = nodesTotal.item(i);    //Setando o nó filho a var!
		oVlrTotal     = vNodeTotal.text;       //Obtendo os valores do nó passando para var


		// Montando o Array!
		aResultado["correcao"] = oVlrCorrecao;
		aResultado["juros"]    = oVlrJuros;
		aResultado["multa"]    = oVlrMulta;
		aResultado["subtotal"] = oVlrSubTotal;
		aResultado["comissao"] = oVlrComissao;
		aResultado["total"]    = oVlrTotal
	}

	//--->Retornando o Array!
	return aResultado;

}//FIM fRetornaCobValoresXML

