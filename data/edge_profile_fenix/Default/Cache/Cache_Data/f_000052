function check_cpf (StrCPF) {
 StrCPF = StrCPF.replace(/\D/g, ''); //Remove tudo o que năo é dígito
 const qtdeDigitos = 11;

 let aTemp = StrCPF.split(''); // transforma a string cpf em matriz
 const aSequencia = aTemp.splice(0, 9); // cria a matriz sequencia REMOVENDO os 9 primeiro números da matriz aCpf
 const aDigitos = aTemp.splice(0, 2); // cria a matriz digitos REMOVENDO  os números restantes da matriz aCpf

 // invalidade se năo possui a quantidade correta de digitos
 if (StrCPF.length !== qtdeDigitos)
   return false;

 // invalida se todos os digitos forem iguais
 const iguais = [...aSequencia, ...aDigitos].reduce((ultimo, valor) => { return (ultimo === valor ? valor : 'nao') });
 if (iguais !== 'nao')
   return false;

 // invalida se o primeiro digito incorreto
 if (!validaDigito(aSequencia, aDigitos[0]))
   return false;

 // invalida se o segundo digito incorreto
 if (!validaDigito([...aSequencia, aDigitos[0]], aDigitos[1]))
   return false;

 return true;
}

const validaDigito = (aSequencia, iDigito) => {
   const soma = aSequencia.reduce((acumulador, valor, index) => Number.parseInt(acumulador) + (Number.parseInt(valor) * (aSequencia.length + 1 - index)), 0);
   const resto = (soma * 10 % 11) === 10 ? 0 : soma * 10 % 11; // resto = 10 vale 0
   return resto === Number.parseInt(iDigito);
}

