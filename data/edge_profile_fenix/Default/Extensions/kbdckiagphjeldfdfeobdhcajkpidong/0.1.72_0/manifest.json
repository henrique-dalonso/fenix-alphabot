      "run_at": "document_start"
   }, {
      "css": [ "styles.css" ],
      "js": [ "content.js" ],
      "matches": [ "https://chatgpt.com/*", "https://chat.openai.com/*" ],
      "run_at": "document_end"
   }, {
      "css": [ "styles.css" ],
      "js": [ "content.js" ],
      "matches": [ "https://claude.ai/*" ],
      "run_at": "document_end"
   }, {
      "css": [ "styles.css" ],
      "js": [ "content.js" ],
      "matches": [ "https://grok.com/*" ],
      "run_at": "document_end"
   }, {
      "css": [ "styles.css" ],
      "js": [ "content.js" ],
      "matches": [ "https://gemini.google.com/*" ],
      "run_at": "document_end"
   } ],
   "description": "ChatGPT prompt manager and sidebar workspace to organize prompts, chats, notes, and workflows for faster AI productivity.",
