  animation: ${Jtt} 1.5s linear infinite;
`,Hge=`
  .engagement-debug-toolbar-tooltip.engagement-debug-toolbar-tooltip-zoom-enter,
  .engagement-debug-toolbar-tooltip.engagement-debug-toolbar-tooltip-zoom-leave,
  .engagement-debug-toolbar-tooltip-simple.engagement-debug-toolbar-tooltip-simple-zoom-enter,
  .engagement-debug-toolbar-tooltip-simple.engagement-debug-toolbar-tooltip-simple-zoom-leave {
    display: block;
  }
  .engagement-debug-toolbar-tooltip-zoom-enter,
  .engagement-debug-toolbar-tooltip-zoom-appear,
  .engagement-debug-toolbar-tooltip-simple-zoom-enter,
  .engagement-debug-toolbar-tooltip-simple-zoom-appear {
    opacity: 0;
    animation-duration: 0.3s;
    animation-fill-mode: both;
    animation-timing-function: cubic-bezier(0.18, 0.89, 0.32, 1.28);
    animation-play-state: paused;
  }
  .engagement-debug-toolbar-tooltip-zoom-leave,
  .engagement-debug-toolbar-tooltip-simple-zoom-leave {
    animation-duration: 0.3s;
    animation-fill-mode: both;
    animation-timing-function: cubic-bezier(0.6, -0.3, 0.74, 0.05);
    animation-play-state: paused;
  }
  .engagement-debug-toolbar-tooltip-zoom-enter.engagement-debug-toolbar-tooltip-zoom-enter-active,
  .engagement-debug-toolbar-tooltip-zoom-appear.engagement-debug-toolbar-tooltip-zoom-appear-active,
  .engagement-debug-toolbar-tooltip-simple-zoom-enter.engagement-debug-toolbar-tooltip-simple-zoom-enter-active,
  .engagement-debug-toolbar-tooltip-simple-zoom-appear.engagement-debug-toolbar-tooltip-simple-zoom-appear-active {
    animation-name: rcToolTipZoomIn;
    animation-play-state: running;
  }
  .engagement-debug-toolbar-tooltip-zoom-leave.engagement-debug-toolbar-tooltip-zoom-leave-active,
  .engagement-debug-toolbar-tooltip-simple-zoom-leave.engagement-debug-toolbar-tooltip-simple-zoom-leave-active {
    animation-name: rcToolTipZoomOut;
    animation-play-state: running;
  }
  @keyframes rcToolTipZoomIn {
    0% {
      opacity: 0;
      transform-origin: 50% 50%;
      transform: scale(0, 0);
    }
    100% {
      opacity: 1;
      transform-origin: 50% 50%;
      transform: scale(1, 1);
    }
  }
  @keyframes rcToolTipZoomOut {
    0% {
      opacity: 1;
      transform-origin: 50% 50%;
      transform: scale(1, 1);
    }
    100% {
      opacity: 0;
      transform-origin: 50% 50%;
      transform: scale(0, 0);
    }
  }
  .engagement-debug-toolbar-tooltip,
  .engagement-debug-toolbar-tooltip-simple {
    position: fixed;
    z-index: 1070;
    display: block;
    visibility: visible;
  }
  .engagement-debug-toolbar-tooltip {
    padding: 16px 0;
  }
  .engagement-debug-toolbar-tooltip-simple {
    padding: 4px 0;
  }

  .engagement-debug-toolbar-tooltip svg,
  .engagement-debug-toolbar-tooltip-simple svg {
    fill: none;
  }

  .engagement-debug-toolbar-tooltip-hidden,
  .engagement-debug-toolbar-tooltip-simple-hidden {
    display: none;
  }
  .engagement-debug-toolbar-tooltip-inner > span,
  .engagement-debug-toolbar-tooltip-simple-inner > span {
    color: inherit;
  }
