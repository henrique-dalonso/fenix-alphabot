  .engagement-recorder-section-tooltip.engagement-recorder-section-tooltip-zoom-enter,
  .engagement-recorder-section-tooltip.engagement-recorder-section-tooltip-zoom-leave {
    display: block;
  }
  .engagement-recorder-section-tooltip-zoom-enter,
  .engagement-recorder-section-tooltip-zoom-appear {
    opacity: 0;
    animation-duration: 0.2s;
    animation-fill-mode: both;
    animation-timing-function: cubic-bezier(0.18, 0.89, 0.32, 1.28);
    animation-play-state: paused;
  }
  .engagement-recorder-section-tooltip-zoom-leave {
    animation-duration: 0.15s;
    animation-fill-mode: both;
    animation-timing-function: cubic-bezier(0.6, -0.3, 0.74, 0.05);
    animation-play-state: paused;
  }
  .engagement-recorder-section-tooltip-zoom-enter.engagement-recorder-section-tooltip-zoom-enter-active,
  .engagement-recorder-section-tooltip-zoom-appear.engagement-recorder-section-tooltip-zoom-appear-active {
    animation-name: rcSectionTooltipZoomIn;
    animation-play-state: running;
  }
  .engagement-recorder-section-tooltip-zoom-leave.engagement-recorder-section-tooltip-zoom-leave-active {
    animation-name: rcSectionTooltipZoomOut;
    animation-play-state: running;
  }
  @keyframes rcSectionTooltipZoomIn {
    0% {
      opacity: 0;
      transform-origin: 50% 50%;
      transform: scale(0.95, 0.95);
    }
    100% {
      opacity: 1;
      transform-origin: 50% 50%;
      transform: scale(1, 1);
    }
  }
  @keyframes rcSectionTooltipZoomOut {
    0% {
      opacity: 1;
      transform-origin: 50% 50%;
      transform: scale(1, 1);
    }
    100% {
      opacity: 0;
      transform-origin: 50% 50%;
      transform: scale(0.95, 0.95);
    }
  }
  .engagement-recorder-section-tooltip {
    position: fixed;
    z-index: 1070;
    display: block;
    visibility: visible;
    padding: 8px 0;
  }
  .engagement-recorder-section-tooltip svg {
    fill: none;
  }
  .engagement-recorder-section-tooltip-hidden {
    display: none;
  }
  .engagement-recorder-section-tooltip-inner > span {
    color: inherit;
  }
